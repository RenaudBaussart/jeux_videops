{
  "extends": ["google"],
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "require-jsdoc": "off",
    "valid-jsdoc": "off",
    "linebreak-style": 0,
    "max-len": ["error", { "code": 180 }]
  }
}